name: telco_churn_ci

conda_env: conda.yaml

entry_points:
  main:
    parameters:
      data_dir: {type: str, default: "telco_preprocessing"}
      n_estimators: {type: int, default: 200}
      max_depth: {type: int, default: 20}
    command: >-
      python modelling.py
      --data_dir {data_dir}
      --n_estimators {n_estimators}
      --max_depth {max_depth}
